<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1,maximum-scale=1" />
<title>Supabase Navigasyon</title>

<link rel="stylesheet"
 href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
body { margin:0; padding:0; background:#0f1115; color:white; font-family:Arial }
.panel { padding:12px; background:#1a1d23; }
.inputbox {
  background:#252931; padding:10px; border-radius:10px;
  display:flex; margin-bottom:8px; align-items:center;
}
input {
  flex:1; background:transparent; border:0; color:white;
  padding:8px; font-size:15px;
}
button {
  padding:10px 14px; border:0; background:#27c55e;
  color:white; border-radius:10px; margin-left:8px;
  font-weight:bold; cursor:pointer;
}
#map { position:fixed; top:150px; bottom:35%; left:0; right:0; }
.steps {
  position:fixed; bottom:0; left:0; right:0; height:35%;
  overflow:auto; background:#1c1f25; padding:10px;
  border-radius:20px 20px 0 0;
}
.step { padding:10px; border-bottom:1px solid #333; }
</style>
</head>

<body>

<div class="panel">
  <div class="inputbox">
    <span>●</span>
    <input id="start" placeholder="Başlangıç (GPS yoksa elle gir)" />
    <button id="btnStartGps">Konumum</button>
  </div>

  <div class="inputbox">
    <span>◆</span>
    <input id="end" placeholder="Varış (BİNA ID / lat lon)" />
    <button id="btnRoute">Rota</button>
  </div>
</div>

<div id="map"></div>
<div class="steps" id="steps"></div>

<script>
/* ---------------------------------------------------------
   1) SUPABASE BİLGİLERİ
--------------------------------------------------------- */
const SUPABASE_URL = "https://luyhfyhwqyzwdjpcfyyn.supabase.co";
const SUPABASE_ANON_KEY = "<BURAYA ANON KEYİNİ YAZ>";

// Kullanıcıya güvenlik için ilk doldurmayı sen yaparsın.

// BİNA ID → Supabase’den koordinat çek
async function supabaseGetCoordsById(binaId) {
  const colID = encodeURIComponent("BİNA ID");
  const colCoords = encodeURIComponent("KOORDİNATLAR");
  const url =
    `${SUPABASE_URL}/rest/v1/bina_liste?${colID}=eq.${binaId}&select=${colCoords}`;

  const res = await fetch(url, {
    headers: {
      apikey: SUPABASE_ANON_KEY,
      Authorization: `Bearer ${SUPABASE_ANON_KEY}`
    }
  });

  if (!res.ok) return null;
  const rows = await res.json();
  if (!rows || !rows.length) return null;

  return parseLatLon(rows[0]["KOORDİNATLAR"]);
}

/* ---------------------------------------------------------
   2) KOORDİNAT PARSE
--------------------------------------------------------- */
function parseLatLon(val) {
  if (!val) return null;
  const p = val.trim().replace(/,/g," ").split(/\s+/);
  if (p.length<2) return null;
  const lat = parseFloat(p[0]);
  const lon = parseFloat(p[1]);
  if (isFinite(lat) && isFinite(lon)) return [lat, lon];
  return null;
}

/* ---------------------------------------------------------
   3) HARİTA
--------------------------------------------------------- */
const map = L.map("map").setView([41.0,29.0],13);
L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

let userMarker=null;
let destMarker=null;
let routeLine=null;

let currentPos=null;       // GPS
let activeRouteCoords=[];  // rota çizgisi
let lastDest=null;

/* ---------------------------------------------------------
   4) SESLİ UYARI
--------------------------------------------------------- */
function speak(msg){
  if(!("speechSynthesis" in window)) return;
  let u = new SpeechSynthesisUtterance(msg);
  u.lang = "tr-TR";
  speechSynthesis.cancel();
  speechSynthesis.speak(u);
}

/* ---------------------------------------------------------
   5) GPS TAKİP — HATA DURUMUNDA MANUEL
--------------------------------------------------------- */
navigator.geolocation.watchPosition(
  p => {
    currentPos = [p.coords.latitude, p.coords.longitude];
    if(!userMarker){
      userMarker = L.marker(currentPos).addTo(map);
    } else userMarker.setLatLng(currentPos);
    map.setView(currentPos,15);
  },
  err => {
    console.log("GPS hata:", err.message);
    speak("Konum alınamadı, manuel başlangıç kullanabilirsiniz.");
    currentPos = null; // manuel moda geçiyoruz
  },
  { enableHighAccuracy:true }
);

/* ---------------------------------------------------------
   6) OSRM ROTA ÇİZ
--------------------------------------------------------- */
async function drawRoute(startLL,endLL){
  const url=
   `https://router.project-osrm.org/route/v1/driving/`+
   `${startLL[1]},${startLL[0]};${endLL[1]},${endLL[0]}`
   +`?overview=full&geometries=geojson&steps=true`;

  const r = await fetch(url);
  const js = await r.json();
  if(!js.routes || !js.routes.length){
    speak("Rota bulunamadı");
    return;
  }

  const rt = js.routes[0];
  const coords = rt.geometry.coordinates.map(([lon,lat])=>[lat,lon]);
  activeRouteCoords = coords;

  if(routeLine) map.removeLayer(routeLine);
  routeLine = L.polyline(coords,{color:"#4da3ff",weight:6}).addTo(map);
  map.fitBounds(routeLine.getBounds(),{padding:[30,30]});

  showSteps(rt.legs[0].steps);
}

/* ---------------------------------------------------------
   7) ADIM LİSTELE
--------------------------------------------------------- */
function showSteps(steps){
  const box=document.getElementById("steps");
  box.innerHTML="";
  steps.forEach((s,i)=>{
    box.innerHTML+=`<div class="step">${i+1}. ${s.maneuver.instruction}</div>`;
  });
}

/* ---------------------------------------------------------
   8) ROTA SAPMA OTOMATİK DÜZELTME
--------------------------------------------------------- */
function haversine(a,b){
  const R=6371000;
  const toRad=x=>x*Math.PI/180;
  const dLat=toRad(b[0]-a[0]);
  const dLon=toRad(b[1]-a[1]);
  const lat1=toRad(a[0]);
  const h=Math.sin(dLat/2)**2 +
           Math.cos(lat1)*Math.cos(toRad(b[0]))*
           Math.sin(dLon/2)**2;
  return 2*R*Math.asin(Math.sqrt(h));
}

let lastRecalc=0;

async function checkDeviation(){
  if(!currentPos||!activeRouteCoords.length||!lastDest) return;
  let min=Infinity;
  for(let i=0;i<activeRouteCoords.length;i+=5){
    const d= haversine(currentPos,activeRouteCoords[i]);
    if(d<min) min=d;
  }
  if(min>40 && Date.now()-lastRecalc>8000){
    lastRecalc=Date.now();
    speak("Rota yeniden hesaplanıyor");
    await drawRoute(currentPos,lastDest);
    speak("Yeni rota hazır");
  }
}

setInterval(checkDeviation,2000);

/* ---------------------------------------------------------
   9) ROTA OLUŞTUR BUTONU
--------------------------------------------------------- */
document.getElementById("btnRoute").onclick = async ()=>{
  
  let startLL = currentPos;
  
  // Eğer GPS yoksa → manuel başlangıç dene
  if(!startLL){
    let sVal = document.getElementById("start").value.trim();
    startLL = parseLatLon(sVal);
    if(!startLL){
      speak("Başlangıç konumu yok. Lütfen elle girin.");
      return;
    }
  }

  const raw = document.getElementById("end").value.trim();
  let dest=null;

  // Sadece rakam ise → bina ID
  if(/^\d+$/.test(raw)){
    dest = await supabaseGetCoordsById(raw);
    if(!dest){ speak("Bina bulunamadı"); return; }
  } else {
    dest = parseLatLon(raw);
  }

  if(!dest){
    speak("Varış çözülemedi");
    return;
  }

  lastDest = dest;

  if(destMarker) map.removeLayer(destMarker);
  destMarker = L.marker(dest).addTo(map);

  await drawRoute(startLL,dest);
  speak("Rota hazır");
};

/* ---------------------------------------------------------
   10) MANUEL GPS BUTONU
--------------------------------------------------------- */
document.getElementById("btnStartGps").onclick = ()=>{
  if(!currentPos) speak("GPS yok, manuel giriniz");
  else document.getElementById("start").value =
    `${currentPos[0].toFixed(6)}, ${currentPos[1].toFixed(6)}`;
};
</script>
</body>
</html>
